# Required API keys
GOOGLE_API_KEY=your_google_ai_studio_api_key
UPSTAGE_API_KEY=your_upstage_api_key

# Optional API keys
TAVILY_API_KEY=your_tavily_api_key_for_web_search_fallback
LANGSMITH_API_KEY=your_langsmith_api_key_for_tracing

# Model configuration
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004
VISION_MODEL=gemini-2.0-flash

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
TOP_K=8
RERANK_TOP_K=4
RERANKER_MODEL=BAAI/bge-reranker-base

# Application
APP_NAME="PDF Q&A Bot"
DEBUG=false
